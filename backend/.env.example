SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=sqlite:///./tempo_tailor.db
LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=  # Optional: model ID if LM Studio doesn't pick up loaded model
# SKIP_JUDGE_TRACKS=false  # LLM judges tracks for vibe fit; set true to skip (faster)

# Deezer (music discovery) - optional override
# DEEZER_BASE_URL=https://api.deezer.com
